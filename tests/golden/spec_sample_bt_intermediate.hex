# Page IB = 0x0000000000008200 (33280)
# Page size = 512 bytes
# BTPAGE: cEnt=0x03, cEntMax=0x14, cbEnt=0x18, cLevel=1 (intermediate)
# PAGETRAILER: ptype=0x81 (NBT), ptypeRepeat=0x81, wSig=0x8006, dwCRC=0x02E8B164, bid=0x0000000000000206
