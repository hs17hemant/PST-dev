# [MS-PST] §3.7 — Sample SLBLOCK (smallest possible: 64 bytes)
# Source: https://learn.microsoft.com/en-us/openspecs/office_file_formats/ms-pst/fa684e53-de03-4e71-86b3-b99277200c88
# Block IB = 0x0000000000594D80
# Block size = 64 bytes (8-byte SLBLOCK header + 1 * 24-byte SLENTRY + 16-byte zero-pad + 16-byte BLOCKTRAILER)
# SLBLOCK header: btype=0x02, cLevel=0x00, cEnt=0x0001
# SLENTRY: nid=0x0000817F, bidData=0x0000000000001380, bidSub=0x0000000000000000
# BLOCKTRAILER: cb=0x0020 (32), cRef=0x5E5F, dwCRC=0xD9D45E50, bid=0x0000000000001386
0000000000594D80  02 00 01 00 00 00 00 00-7F 81 00 00 00 00 00 00
0000000000594D90  80 13 00 00 00 00 00 00-00 00 00 00 00 00 00 00
0000000000594DA0  00 00 00 00 00 00 00 00-00 00 00 00 00 00 00 00
0000000000594DB0  20 00 5F 5E 50 5E D4 D9-86 13 00 00 00 00 00 00
